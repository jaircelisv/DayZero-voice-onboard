{
  "name": "dayzero-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DayZero webhook + config generator. Receives Vapi end-of-call reports, persists to Redis, calls generate-config, and publishes cited.md audit entries.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "heroku-postbuild": "npm run build",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "openai": "^4.65.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "stripe": "^17.7.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
