# DayZero backend · local env
# Copy to .env.local and fill in.

PORT=3000
NODE_ENV=development

# Vapi
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ONBOARDER_NUMBER=+14433919140

# Redis (Redis Cloud or local docker)
REDIS_URL=redis://localhost:6379

# OpenAI (used by /api/generate-config to turn transcript → YAML)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# InsForge
INSFORGE_API_KEY=
INSFORGE_PROJECT_ID=

# Wundergraph
WUNDERGRAPH_TOKEN=

# Guild (event signing)
GUILD_API_KEY=

# Public base URL of this backend (set after deploy)
PUBLIC_BASE_URL=http://localhost:3000
